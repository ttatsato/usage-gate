{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(SQLX_OFFLINE=true cargo build)",
      "Bash(SQLX_OFFLINE=true cargo build:*)",
      "Bash(cargo sqlx prepare:*)",
      "Bash(sqlx database:*)",
      "Bash(sqlx migrate:*)",
      "Bash(docker compose:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker exec usage-gate-db:*)",
      "Bash(docker exec usage-gate-valkey:*)",
      "Bash(PGPASSWORD=usage_gate psql:*)",
      "Bash(RATE_LIMITER_URL=redis://localhost:6380 cargo test)",
      "Bash(RATE_LIMITER_URL=redis://localhost:6380 cargo test:*)",
      "Bash(RATE_LIMITER=valkey RATE_LIMITER_URL=redis://localhost:6380 cargo test)",
      "Bash(RATE_LIMITER=valkey RATE_LIMITER_URL=redis://localhost:6380 cargo test:*)",
      "Bash(QUOTA_COUNTER=valkey QUOTA_COUNTER_URL=redis://localhost:6380 cargo test:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$f\" == *.rs ]] && rustfmt --edition 2024 \"$f\" 2>/dev/null; exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\"; nc -z localhost 5433 2>/dev/null || exit 0; out=$(cargo check --quiet 2>&1); rc=$?; [ $rc -ne 0 ] && printf '%s' \"$out\" | tail -30 | jq -Rs '{systemMessage: (\"cargo check failed at Stop:\\n\" + .)}'; exit 0",
            "timeout": 60,
            "statusMessage": "cargo check (Stop hook)"
          }
        ]
      }
    ]
  }
}
